---
import { languagesAndTools } from "@/data/languages-and-tools";
---

<section class="space-y-8 slide-up">
  <h2 class="text-3xl font-semibold bg-gradient-to-r from-[#d0486e] to-[#7560c9] bg-clip-text text-transparent inline-block">
    Languages & Tools
  </h2>

  <div class="grid grid-cols-3 gap-6 justify-center">
    {languagesAndTools.map((item) => (
      <div class="flex flex-col items-center gap-1">
        <img
          src={item.src}
          alt={`${item.name} icon`}
          height={40}
          width={40}
          class="hover:scale-120 duration-300"
        />
        <p>{item.name}</p>
      </div>
    ))}
  </div>
</section>

<style>
  @keyframes fadeInSlideUp {
    from {
      opacity: 0;
      transform: translateY(100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .slide-up {
    animation: fadeInSlideUp 1s ease-out forwards;
  }
</style>
