---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
---

<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };

  const isDark = getThemePreference() === "dark"
  document.documentElement.classList.toggle("dark", isDark);

  if (typeof localStorage !== "undefined") {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }

  // https://docs.astro.build/en/guides/view-transitions/#astrobefore-swap
  document.addEventListener("astro:before-swap", ({ newDocument }) => {
    const isDark = getThemePreference() === "dark";
    newDocument.documentElement.classList.toggle("dark", isDark);
  });
</script>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Neil Francis Palmares</title>
    <ClientRouter />
  </head>
  <body class="antialiased">
    <div class="min-h-screen bg-white dark:bg-black text-black dark:text-white transition-colors duration-300">
      <slot />
    </div>
  </body>
</html>
